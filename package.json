{
  "name": "book-your-resort",
  "version": "0.1.0",
  "private": true,
"scripts": {
  "dev": "next dev",
  "dev:turbo": "next dev --turbopack",
  "dev:webpack": "next dev --webpack",
  "clean:next": "node -e \"const fs=require('fs'); fs.rmSync('.next',{recursive:true,force:true}); console.log('Removed .next cache');\"",
  "reinstall": "node -e \"const fs=require('fs'); fs.rmSync('node_modules',{recursive:true,force:true}); fs.rmSync('package-lock.json',{force:true}); console.log('Removed node_modules and package-lock.json');\" && npm install",
  "build": "next build",
  "start": "next start",
  "lint": "eslint"
},
  "dependencies": {
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "next": "16.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.6.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.5.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.4",
    "typescript": "^5"
  }
}
